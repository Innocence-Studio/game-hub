---
const site = {
  name: "NightOwl Codex",
  tagline: "遊んだゲームの攻略・データを、見やすく整理する。",
  description:
    "ESO / FO76 / ARK などの攻略記事・ビルド・アイテム・マップ情報を集約していく個人用ハブです。",
};

const games = [
  {
    key: "eso",
    name: "Elder Scrolls Online",
    short: "ビルド / クエスト / 素材 / マップ",
    tags: ["Build", "Quest", "Map"],
    href: "/games/eso",
  },
  {
    key: "fo76",
    name: "Fallout 76",
    short: "武器 / 防具 / パーク / 周回",
    tags: ["Weapon", "Perk", "Farm"],
    href: "/games/fo76",
  },
  {
    key: "ark",
    name: "ARK (ASA)",
    short: "ブリーディング / 施設 / マップ / ティム",
    tags: ["Breeding", "Map", "Tame"],
    href: "/games/ark",
  },
];

const sections = [
  {
    title: "Guides",
    desc: "初心者〜復帰向けの導線。まず迷子を防ぐ。",
    items: [
      { label: "初心者ガイド", href: "/guides/beginner" },
      { label: "おすすめ設定", href: "/guides/settings" },
      { label: "よくある質問", href: "/guides/faq" },
    ],
  },
  {
    title: "Maps",
    desc: "拡大縮小できる地図＋ピン（後で実装）。",
    items: [
      { label: "ARK: The Island", href: "/maps/ark-island" },
      { label: "ESO: Zone Index", href: "/maps/eso-zones" },
      { label: "FO76: Appalachia", href: "/maps/fo76-appalachia" },
    ],
  },
  {
    title: "Tools",
    desc: "電卓/計算ツールなどの“便利機能”置き場。",
    items: [
      { label: "ARK Smart Breeder（構想）", href: "/tools/ark-smart-breeder" },
      { label: "ダメージ計算（予定）", href: "/tools/damage-calc" },
      { label: "素材必要数（予定）", href: "/tools/material-calc" },
    ],
  },
];
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.name}</title>
    <meta name="description" content={site.description} />
    <!-- favicon -->
    <link rel="icon" href="/favicon.ico" />
    <style>
      :root {
        --bg: #0b1020;
        --panel: rgba(255, 255, 255, 0.06);
        --panel2: rgba(255, 255, 255, 0.1);
        --text: rgba(255, 255, 255, 0.92);
        --muted: rgba(255, 255, 255, 0.66);
        --line: rgba(255, 255, 255, 0.1);
        --brand: #7c5cff;
        --brand2: #24d6ff;
        --shadow: 0 16px 50px rgba(0, 0, 0, 0.35);
        --radius: 18px;
        --radius2: 26px;
      }
      * {
        box-sizing: border-box;
      }
      html,
      body {
        height: 100%;
      }
      body {
        margin: 0;
        font-family:
          ui-sans-serif,
          system-ui,
          -apple-system,
          "Segoe UI",
          Roboto,
          "Helvetica Neue",
          Arial;
        color: var(--text);
        background:
          radial-gradient(
            1200px 600px at 20% 10%,
            rgba(124, 92, 255, 0.22),
            transparent 55%
          ),
          radial-gradient(
            1000px 600px at 70% 15%,
            rgba(36, 214, 255, 0.18),
            transparent 55%
          ),
          radial-gradient(
            900px 700px at 50% 90%,
            rgba(255, 122, 89, 0.1),
            transparent 55%
          ),
          var(--bg);
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
        text-underline-offset: 4px;
      }

      .wrap {
        max-width: 1080px;
        margin: 0 auto;
        padding: 28px 18px 60px;
      }
      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 14px;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: rgba(0, 0, 0, 0.18);
        backdrop-filter: blur(10px);
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 800;
        letter-spacing: 0.2px;
      }
      .dot {
        width: 14px;
        height: 14px;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--brand), var(--brand2));
        box-shadow: 0 0 0 6px rgba(124, 92, 255, 0.12);
      }
      .nav {
        display: flex;
        gap: 14px;
        color: var(--muted);
        font-size: 14px;
      }
      .nav a {
        padding: 8px 10px;
        border-radius: 10px;
      }
      .nav a:hover {
        background: rgba(255, 255, 255, 0.06);
        text-decoration: none;
      }

      .hero {
        margin-top: 22px;
        padding: 28px 22px;
        border-radius: var(--radius2);
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.08),
          rgba(255, 255, 255, 0.04)
        );
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
      }
      .hero:before {
        content: "";
        position: absolute;
        inset: -1px;
        background:
          radial-gradient(
            700px 240px at 20% 0%,
            rgba(124, 92, 255, 0.3),
            transparent 60%
          ),
          radial-gradient(
            700px 240px at 80% 0%,
            rgba(36, 214, 255, 0.24),
            transparent 60%
          );
        opacity: 0.9;
        pointer-events: none;
      }
      .heroInner {
        position: relative;
        display: grid;
        gap: 18px;
      }
      .kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--muted);
        font-size: 13px;
        border: 1px solid var(--line);
        padding: 6px 10px;
        border-radius: 999px;
        width: fit-content;
        background: rgba(0, 0, 0, 0.16);
      }
      .kicker span {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: rgba(36, 214, 255, 0.9);
      }
      h1 {
        margin: 0;
        font-size: clamp(28px, 4.4vw, 44px);
        line-height: 1.12;
        letter-spacing: -0.5px;
      }
      .lead {
        margin: 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.7;
        max-width: 70ch;
      }
      .ctaRow {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 4px;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 11px 14px;
        border-radius: 14px;
        border: 1px solid var(--line);
        background: rgba(0, 0, 0, 0.22);
        color: var(--text);
        font-weight: 650;
        font-size: 14px;
        text-decoration: none;
      }
      .btn:hover {
        background: rgba(255, 255, 255, 0.08);
        text-decoration: none;
      }
      .btnPrimary {
        border: none;
        background: linear-gradient(135deg, var(--brand), var(--brand2));
        box-shadow: 0 10px 26px rgba(124, 92, 255, 0.22);
        color: #071018;
      }
      .btnPrimary:hover {
        filter: brightness(1.06);
      }

      .grid {
        margin-top: 20px;
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 12px;
      }
      .card {
        grid-column: span 12;
        padding: 16px 16px;
        border-radius: var(--radius);
        background: var(--panel);
        border: 1px solid var(--line);
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
        transition:
          transform 0.12s ease,
          background 0.12s ease,
          border-color 0.12s ease;
      }
      .card:hover {
        transform: translateY(-2px);
        background: var(--panel2);
        border-color: rgba(255, 255, 255, 0.16);
      }
      .cardTop {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
      }
      .cardTitle {
        margin: 0;
        font-size: 16px;
        letter-spacing: 0.2px;
      }
      .cardDesc {
        margin: 6px 0 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.65;
      }
      .tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 10px;
      }
      .tag {
        font-size: 12px;
        padding: 5px 8px;
        border-radius: 999px;
        border: 1px solid var(--line);
        color: var(--muted);
        background: rgba(0, 0, 0, 0.14);
      }

      .section {
        margin-top: 22px;
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 12px;
      }
      .pane {
        grid-column: span 12;
        padding: 16px;
        border-radius: var(--radius);
        background: rgba(0, 0, 0, 0.18);
        border: 1px solid var(--line);
      }
      .pane h2 {
        margin: 0;
        font-size: 15px;
      }
      .pane p {
        margin: 6px 0 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.65;
      }
      .list {
        margin: 12px 0 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 8px;
      }
      .item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 14px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.04);
      }
      .item:hover {
        background: rgba(255, 255, 255, 0.08);
      }
      .arrow {
        color: var(--muted);
      }

      .footer {
        margin-top: 28px;
        color: rgba(255, 255, 255, 0.55);
        font-size: 12px;
        display: flex;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
      }

      @media (min-width: 760px) {
        .card {
          grid-column: span 4;
        }
        .pane {
          grid-column: span 4;
        }
      }
    </style>
  </head>

  <body>
    <div class="wrap">
      <header class="topbar">
        <div class="brand">
          <span class="dot" aria-hidden="true"></span>
          <span>{site.name}</span>
        </div>
        <nav class="nav" aria-label="primary">
          <a href="/games">Games</a>
          <a href="/guides">Guides</a>
          <a href="/maps">Maps</a>
          <a href="/tags">Tags</a>
        </nav>
      </header>

      <main>
        <section class="hero">
          <div class="heroInner">
            <div class="kicker"><span></span>公開中：Cloudflare Pages</div>
            <h1>
              {site.tagline}
            </h1>
            <p class="lead">{site.description}</p>

            <div class="ctaRow">
              <a class="btn btnPrimary" href="/games">ゲームを探す</a>
              <a class="btn" href="/guides/beginner">初心者ガイド</a>
              <a class="btn" href="/maps">マップ</a>
            </div>
          </div>
        </section>

        <section class="grid" aria-label="games">
          {
            games.map((g) => (
              <a class="card" href={g.href}>
                <div class="cardTop">
                  <h3 class="cardTitle">{g.name}</h3>
                  <span class="arrow">→</span>
                </div>
                <p class="cardDesc">{g.short}</p>
                <div class="tags">
                  {g.tags.map((t) => (
                    <span class="tag">{t}</span>
                  ))}
                </div>
              </a>
            ))
          }
        </section>

        <section class="section" aria-label="sections">
          {
            sections.map((s) => (
              <div class="pane">
                <h2>{s.title}</h2>
                <p>{s.desc}</p>
                <ul class="list">
                  {s.items.map((it) => (
                    <li>
                      <a class="item" href={it.href}>
                        <span>{it.label}</span>
                        <span class="arrow">→</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </section>

        <div class="footer">
          <span>© {new Date().getFullYear()} {site.name}</span>
          <span>更新は GitHub に push → 自動デプロイ</span>
        </div>
      </main>
    </div>
  </body>
</html>
