---
const site = {
  name: "Game Hub",
  tagline: "遊んだゲームの情報を、見やすく整える。",
  description:
    "ESO、Fallout 76、ARK ASA を中心に、攻略メモ・ビルド・素材情報・周回データなどを整理していく個人用ゲームハブです。",
};

const heroSlides = [
  {
    type: "video",
    title: "Game Hub Main Visual",
    subtitle: "攻略・データ・メモをまとめる総合ハブ",
    description:
      "サイト全体の世界観を見せるメインビジュアルです。ロゴや代表イメージを置く枠としてお使いいただけます。",
    src: "https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4",
    poster:
      "https://images.unsplash.com/photo-1511512578047-dfb367046420?auto=format&fit=crop&w=1600&q=80",
    alt: "ゲーム環境を思わせるサイトメインビジュアル動画",
    href: "#featured",
    cta: "おすすめページを見る",
  },
  {
    type: "image",
    title: "Elder Scrolls Online",
    subtitle: "Build / Quest / Map",
    description:
      "ESO のビルドやクエスト、マップ整理ページへつながるイメージスライドです。",
    src: "https://images.unsplash.com/photo-1542751371-adc38448a05e?auto=format&fit=crop&w=1600&q=80",
    alt: "ファンタジーRPGを想起させるゲームイメージ",
    href: "/games/eso/",
    cta: "ESO を見る",
  },
  {
    type: "image",
    title: "Fallout 76",
    subtitle: "Weapon / Perk / Farm",
    description:
      "FO76 の武器、防具、周回メモなどを扱うページ用のイメージスライドです。",
    src: "https://images.unsplash.com/photo-1534423861386-85a16f5d13fd?auto=format&fit=crop&w=1600&q=80",
    alt: "SF系サバイバルゲームを想起させるイメージ",
    href: "/games/fo76/",
    cta: "FO76 を見る",
  },
  {
    type: "image",
    title: "ARK: Survival Ascended",
    subtitle: "Breeding / Tame / Map",
    description:
      "ARK のブリーディング、テイム、マップ情報などへつながるイメージスライドです。",
    src: "https://images.unsplash.com/photo-1518709268805-4e9042af2176?auto=format&fit=crop&w=1600&q=80",
    alt: "自然と冒険を感じるサバイバルゲームイメージ",
    href: "/games/ark/",
    cta: "ARK を見る",
  },
];

const navItems = [
  { label: "Games", href: "#games" },
  { label: "Updates", href: "#updates" },
  { label: "Featured", href: "#featured" },
];

const games = [
  {
    key: "eso",
    badge: "Elder Scrolls Online",
    title: "ESO",
    description:
      "ビルド、クエスト、素材、マップ、収集系の情報を整理する想定です。",
    tags: ["Build", "Quest", "Map"],
    href: "/games/eso/",
  },
  {
    key: "fo76",
    badge: "Fallout 76",
    title: "FO76",
    description:
      "武器、防具、パーク、イベント、周回メモなどをまとめる領域でございます。",
    tags: ["Weapon", "Perk", "Farm"],
    href: "/games/fo76/",
  },
  {
    key: "ark",
    badge: "ARK: Survival Ascended",
    title: "ARK",
    description:
      "ブリーディング、施設、マップ、テイム、サーバーメモなどを整理する想定です。",
    tags: ["Breeding", "Map", "Tame"],
    href: "/games/ark/",
  },
  {
    key: "future",
    badge: "Coming Soon",
    title: "追加予定",
    description:
      "今後追加するゲームやシリーズの置き場です。FF14 や新作タイトルにも拡張しやすい構成にしてあります。",
    tags: ["Future", "WIP"],
    href: "/games/",
  },
];

const updates = [
  {
    date: "2026.03.06 / ARK",
    title: "ARK ブリーディング用メモページを追加",
    description:
      "ステータス比較や管理用ページへの導線を配置する想定の更新情報カードです。",
  },
  {
    date: "2026.03.05 / ESO",
    title: "ESO のカテゴリ構成を整理",
    description:
      "ビルド、クエスト、素材、マップなど、今後の増設を見越した分類の土台として使えます。",
  },
  {
    date: "2026.03.04 / Site",
    title: "トップページの導線とレイアウトを調整",
    description:
      "ゲーム一覧・更新情報・おすすめページを見やすく並べるための UI 改善例でございます。",
  },
];

const featuredPages = [
  {
    label: "Guide",
    title: "初めて見る人向けの総合ガイド",
    description:
      "サイトの見方、各ゲームページの構成、更新方針などをまとめた案内ページ向けです。",
    href: "/guide/",
  },
  {
    label: "Data",
    title: "よく使うデータベース一覧",
    description:
      "素材一覧、装備一覧、エリア一覧など、参照頻度の高いページへの導線に向いております。",
    href: "/database/",
  },
  {
    label: "Note",
    title: "制作メモ・更新予定",
    description:
      "今後追加する予定のカテゴリや、仮置き中のメモをまとめるページとして使えます。",
    href: "/notes/",
  },
];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.name}</title>
    <meta name="description" content={site.description} />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="#top" aria-label="Game Hub home">
          <div class="brand-mark" aria-hidden="true">
            <span>🦉</span>
          </div>
          <div class="brand-text">
            <p class="brand-title">{site.name}</p>
            <p class="brand-subtitle">
              攻略・データ・メモを見やすく整理する個人ハブ
            </p>
          </div>
        </a>

        <nav class="header-nav" aria-label="Main navigation">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>

        <div class="lang-switch" aria-label="Language switcher">
          <a href="#" class="is-active" lang="ja">JA</a>
          <a href="#" lang="en">EN</a>
        </div>
      </div>
    </header>

    <main id="top">
      <section class="hero hero-lp">
        <div class="hero-slider hero-slider-full" aria-label="Hero slideshow">
          {
            heroSlides.map((slide, index) => (
              <article
                class={`hero-slide ${index === 0 ? "is-active" : ""}`}
                aria-hidden={index === 0 ? "false" : "true"}
                data-slide
              >
                {slide.type === "video" ? (
                  <video
                    class="hero-media"
                    autoplay={index === 0}
                    muted
                    loop
                    playsinline
                    preload={index === 0 ? "auto" : "metadata"}
                    poster={slide.poster}
                    aria-label={slide.alt}
                  >
                    <source src={slide.src} type="video/mp4" />
                  </video>
                ) : (
                  <img
                    class="hero-media"
                    src={slide.src}
                    alt={slide.alt}
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                )}
                <div class="hero-slide-overlay" />
              </article>
            ))
          }

          <div class="container hero-overlay-content">
            <div class="hero-copy hero-copy-lp">
              <div class="hero-kicker">Game Database / Guide Hub</div>
              <h1>{site.tagline}</h1>
              <p class="hero-lead">
                {site.description}
                攻略、ビルド、素材、周回、サーバーメモまで、あとで探しやすい形で整えていくためのトップページです。
              </p>

              <div class="hero-actions">
                <a class="button button-primary" href="#games">
                  ゲーム一覧を見る
                </a>
                <a class="button button-secondary" href="#featured">
                  おすすめページへ
                </a>
              </div>

              <div class="hero-points hero-points-lp">
                <div class="hero-point">
                  <strong>ゲームごとに整理</strong>
                  <span>ESO / FO76 / ARK ASA を入口から分かりやすく分類</span>
                </div>
                <div class="hero-point">
                  <strong>更新を追いやすい</strong>
                  <span>追加した記事やメモをトップからすぐ確認できます</span>
                </div>
                <div class="hero-point">
                  <strong>公開・限定公開にも対応しやすい</strong>
                  <span>あとからページの見せ分けをしやすい素直な構成です</span>
                </div>
              </div>
            </div>
          </div>

          <div
            class="hero-slider-dots hero-slider-dots-lp"
            aria-label="Hero slide indicators"
          >
            {
              heroSlides.map((slide, index) => (
                <button
                  type="button"
                  class={`hero-dot ${index === 0 ? "is-active" : ""}`}
                  aria-label={`${slide.title} を表示`}
                  aria-pressed={index === 0 ? "true" : "false"}
                  data-dot={index}
                />
              ))
            }
          </div>
        </div>

        <div class="container hero-bottom-panels">
          <div class="hero-mini-card">
            <div class="meta">Main Contents</div>
            <h2>攻略・データ・記録をひとつに集約</h2>
            <p>
              ゲームごとの攻略情報、素材情報、ビルド、メモ、周回記録を、
              自分でも見返しやすく、必要なら公開もしやすい形で整理します。
            </p>
          </div>

          <div class="hero-mini-grid">
            <article class="hero-mini-item">
              <strong>ESO</strong>
              <span>Build / Quest / Map</span>
            </article>
            <article class="hero-mini-item">
              <strong>FO76</strong>
              <span>Weapon / Perk / Farm</span>
            </article>
            <article class="hero-mini-item">
              <strong>ARK ASA</strong>
              <span>Breeding / Tame / Map</span>
            </article>
          </div>
        </div>
      </section>

      <section class="section" id="games">
        <div class="container">
          <div class="section-header">
            <div>
              <h2 class="section-title">ゲーム一覧</h2>
              <p class="section-text">
                ゲームごとの入口を並べるメインエリアです。まずは主要タイトルをカード形式で見せると分かりやすくなります。
              </p>
            </div>
            <a class="section-link" href="#top">トップへ戻る</a>
            <a href="/public/test">publicテストページ</a>
          </div>

          <div class="game-grid">
            {
              games.map((game) => (
                <article class="card game-card">
                  <div class={`game-thumb ${game.key}`}>
                    <span class="game-badge">{game.badge}</span>
                  </div>
                  <div class="game-body">
                    <h3 class="game-title">{game.title}</h3>
                    <p class="game-description">{game.description}</p>
                    <div class="tag-list">
                      {game.tags.map((tag) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                    <a class="card-link" href={game.href}>
                      詳細を見る →
                    </a>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section" id="updates">
        <div class="container">
          <div class="section-header">
            <div>
              <h2 class="section-title">最新記事 / 更新情報</h2>
              <p class="section-text">
                更新内容を数件だけ見せると、トップページが生きたサイトに見えやすくなります。
              </p>
            </div>
          </div>

          <div class="update-grid">
            {
              updates.map((item) => (
                <article class="card update-card">
                  <div class="meta">{item.date}</div>
                  <h3 class="update-title">{item.title}</h3>
                  <p class="update-text">{item.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section" id="featured">
        <div class="container">
          <div class="section-header">
            <div>
              <h2 class="section-title">おすすめページ</h2>
              <p class="section-text">
                よく見てほしいページや、入口として便利なページを並べると回遊しやすくなります。
              </p>
            </div>
          </div>

          <div class="feature-grid">
            {
              featuredPages.map((page) => (
                <article class="card feature-card">
                  <div class="meta">{page.label}</div>
                  <h3 class="feature-title">{page.title}</h3>
                  <p class="feature-text">{page.description}</p>
                  <a class="card-link" href={page.href}>
                    ページを見る →
                  </a>
                </article>
              ))
            }
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <p class="brand-title">{site.name}</p>
          <p>
            遊んだゲームの攻略・データ・記録を整理するための個人用サイトです。公開ページと限定ページを将来的に分けやすい、素直なトップ構成にしてあります。
          </p>
        </div>

        <div class="footer-links">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </div>
      </div>
    </footer>

    <script is:inline>
      const slides = Array.from(document.querySelectorAll("[data-slide]"));
      const dots = Array.from(document.querySelectorAll("[data-dot]"));
      const intervalMs = 5000;
      let currentIndex = 0;
      let timerId;

      const controlVideo = (slide, isActive) => {
        const video = slide.querySelector("video");
        if (!video) return;

        if (isActive) {
          video.currentTime = 0;
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      };

      const setActiveSlide = (nextIndex) => {
        slides.forEach((slide, index) => {
          const isActive = index === nextIndex;
          slide.classList.toggle("is-active", isActive);
          slide.setAttribute("aria-hidden", String(!isActive));
          controlVideo(slide, isActive);
        });

        dots.forEach((dot, index) => {
          const isActive = index === nextIndex;
          dot.classList.toggle("is-active", isActive);
          dot.setAttribute("aria-pressed", String(isActive));
        });

        currentIndex = nextIndex;
      };

      const startSlider = () => {
        clearInterval(timerId);
        timerId = window.setInterval(() => {
          const nextIndex = (currentIndex + 1) % slides.length;
          setActiveSlide(nextIndex);
        }, intervalMs);
      };

      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => {
          setActiveSlide(index);
          startSlider();
        });
      });

      if (slides.length > 1) {
        setActiveSlide(0);
        startSlider();
      } else if (slides.length === 1) {
        setActiveSlide(0);
      }
    </script>
  </body>
</html>

<style>
  :root {
    --bg: #0f172a;
    --bg-soft: #111827;
    --panel: rgba(15, 23, 42, 0.72);
    --line: rgba(148, 163, 184, 0.18);
    --text: #e5eefb;
    --muted: #94a3b8;
    --accent: #7dd3fc;
    --accent-strong: #38bdf8;
    --shadow: 0 18px 50px rgba(0, 0, 0, 0.28);
    --max: 1180px;
    --radius-lg: 24px;
    --radius-md: 18px;
    --radius-sm: 14px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: "Segoe UI", "Hiragino Sans", "Noto Sans JP", sans-serif;
    color: var(--text);
    background:
      radial-gradient(
        circle at top left,
        rgba(56, 189, 248, 0.16),
        transparent 26%
      ),
      radial-gradient(
        circle at top right,
        rgba(34, 197, 94, 0.14),
        transparent 22%
      ),
      linear-gradient(180deg, #020617 0%, #0f172a 38%, #111827 100%);
    line-height: 1.7;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    width: min(calc(100% - 32px), var(--max));
    margin: 0 auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px);
    background: rgba(2, 6, 23, 0.7);
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    min-height: 76px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }

  .brand-mark {
    width: 48px;
    height: 48px;
    border-radius: 16px;
    background: linear-gradient(
      135deg,
      rgba(125, 211, 252, 0.22),
      rgba(59, 130, 246, 0.18)
    );
    border: 1px solid rgba(125, 211, 252, 0.28);
    display: grid;
    place-items: center;
    box-shadow: var(--shadow);
    flex-shrink: 0;
  }

  .brand-mark span {
    font-size: 1.35rem;
  }

  .brand-title {
    margin: 0;
    font-size: 1.02rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .brand-subtitle {
    margin: 2px 0 0;
    color: var(--muted);
    font-size: 0.82rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .header-nav a,
  .lang-switch a {
    padding: 10px 14px;
    border-radius: 999px;
    color: #dbe7f6;
    transition: 0.2s ease;
    font-size: 0.95rem;
  }

  .header-nav a:hover,
  .lang-switch a:hover {
    background: rgba(148, 163, 184, 0.12);
    color: #ffffff;
  }

  .lang-switch {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.58);
  }

  .lang-switch .is-active {
    background: linear-gradient(
      135deg,
      rgba(125, 211, 252, 0.22),
      rgba(56, 189, 248, 0.18)
    );
    color: #ffffff;
    border: 1px solid rgba(125, 211, 252, 0.18);
  }

  .hero-lp {
    padding: 0 0 32px;
  }

  .hero-slider-full {
    position: relative;
    min-height: clamp(560px, 78vh, 860px);
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
    overflow: hidden;
    background: #020617;
  }

  .hero-slider-full .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.9s ease;
  }

  .hero-slider-full .hero-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .hero-slider-full .hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.02);
  }

  .hero-slider-full .hero-slide-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        rgba(2, 6, 23, 0.88) 0%,
        rgba(2, 6, 23, 0.62) 38%,
        rgba(2, 6, 23, 0.38) 68%,
        rgba(2, 6, 23, 0.52) 100%
      ),
      linear-gradient(
        180deg,
        rgba(2, 6, 23, 0.16) 0%,
        rgba(2, 6, 23, 0.46) 100%
      );
  }

  .hero-overlay-content {
    position: relative;
    z-index: 2;
    min-height: clamp(560px, 78vh, 860px);
    display: flex;
    align-items: center;
  }

  .hero-copy-lp {
    width: min(100%, 700px);
    padding: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(56, 189, 248, 0.12);
    border: 1px solid rgba(125, 211, 252, 0.2);
    color: #d9f5ff;
    font-size: 0.88rem;
    margin-bottom: 18px;
  }

  .hero-copy-lp h1 {
    margin: 0;
    font-size: clamp(2.6rem, 6vw, 5rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
    max-width: 11ch;
    text-wrap: balance;
  }

  .hero-lead {
    margin-top: 20px;
    max-width: 42rem;
    font-size: 1.05rem;
    color: #d5e4f5;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  .hero-actions {
    margin-top: 28px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 600;
    transition: 0.2s ease;
  }

  .button-primary {
    background: linear-gradient(135deg, var(--accent), var(--accent-strong));
    color: #082032;
  }

  .button-primary:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }

  .button-secondary {
    border-color: rgba(148, 163, 184, 0.2);
    background: rgba(15, 23, 42, 0.5);
    color: #edf6ff;
  }

  .button-secondary:hover {
    background: rgba(30, 41, 59, 0.8);
  }

  .hero-points {
    display: grid;
    gap: 14px;
    margin-top: 26px;
  }

  .hero-points-lp {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    max-width: 980px;
  }

  .hero-point {
    padding: 14px 16px;
    border-radius: var(--radius-sm);
    background: rgba(2, 6, 23, 0.28);
