---
const site = {
  name: "Game Hub",
  tagline: "遊んだゲームの情報を、見やすく整える。",
  description:
    "ESO、Fallout 76、ARK ASA を中心に、攻略メモ・ビルド・素材情報・周回データなどを整理していく個人用ゲームハブです。",
};

const navItems = [
  { label: "Games", href: "#games" },
  { label: "Updates", href: "#updates" },
  { label: "Featured", href: "#featured" },
];

const games = [
  {
    key: "eso",
    badge: "Elder Scrolls Online",
    title: "ESO",
    description: "ビルド、クエスト、素材、マップ、収集系の情報を整理する想定です。",
    tags: ["Build", "Quest", "Map"],
    href: "/games/eso/",
  },
  {
    key: "fo76",
    badge: "Fallout 76",
    title: "FO76",
    description: "武器、防具、パーク、イベント、周回メモなどをまとめる領域でございます。",
    tags: ["Weapon", "Perk", "Farm"],
    href: "/games/fo76/",
  },
  {
    key: "ark",
    badge: "ARK: Survival Ascended",
    title: "ARK",
    description: "ブリーディング、施設、マップ、テイム、サーバーメモなどを整理する想定です。",
    tags: ["Breeding", "Map", "Tame"],
    href: "/games/ark/",
  },
  {
    key: "future",
    badge: "Coming Soon",
    title: "追加予定",
    description: "今後追加するゲームやシリーズの置き場です。FF14 や新作タイトルにも拡張しやすい構成にしてあります。",
    tags: ["Future", "WIP"],
    href: "/games/",
  },
];

const updates = [
  {
    date: "2026.03.06 / ARK",
    title: "ARK ブリーディング用メモページを追加",
    description:
      "ステータス比較や管理用ページへの導線を配置する想定の更新情報カードです。",
  },
  {
    date: "2026.03.05 / ESO",
    title: "ESO のカテゴリ構成を整理",
    description:
      "ビルド、クエスト、素材、マップなど、今後の増設を見越した分類の土台として使えます。",
  },
  {
    date: "2026.03.04 / Site",
    title: "トップページの導線とレイアウトを調整",
    description:
      "ゲーム一覧・更新情報・おすすめページを見やすく並べるための UI 改善例でございます。",
  },
];

const featuredPages = [
  {
    label: "Guide",
    title: "初めて見る人向けの総合ガイド",
    description:
      "サイトの見方、各ゲームページの構成、更新方針などをまとめた案内ページ向けです。",
    href: "/guide/",
  },
  {
    label: "Data",
    title: "よく使うデータベース一覧",
    description:
      "素材一覧、装備一覧、エリア一覧など、参照頻度の高いページへの導線に向いております。",
    href: "/database/",
  },
  {
    label: "Note",
    title: "制作メモ・更新予定",
    description:
      "今後追加する予定のカテゴリや、仮置き中のメモをまとめるページとして使えます。",
    href: "/notes/",
  },
];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.name}</title>
    <meta name="description" content={site.description} />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="#top" aria-label="Game Hub home">
          <div class="brand-mark" aria-hidden="true">
            <span>🦉</span>
          </div>
          <div class="brand-text">
            <p class="brand-title">{site.name}</p>
            <p class="brand-subtitle">攻略・データ・メモを見やすく整理する個人ハブ</p>
          </div>
        </a>

        <nav class="header-nav" aria-label="Main navigation">
          {navItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>

        <div class="lang-switch" aria-label="Language switcher">
          <a href="#" class="is-active" lang="ja">JA</a>
          <a href="#" lang="en">EN</a>
        </div>
      </div>
    </header>

    <main id="top">
      <section class="hero">
        <div class="container hero-grid">
          <div class="hero-copy">
            <div class="hero-kicker">Game Database / Guide Hub</div>
            <h1>{site.tagline}</h1>
            <p>{site.description} すぐ探せて、あとで見返しやすい構成を目指したトップページです。</p>

            <div class="hero-actions">
              <a class="button button-primary" href="#games">ゲーム一覧を見る</a>
              <a class="button button-secondary" href="#updates">更新情報を見る</a>
            </div>

            <div class="hero-points">
              <div class="hero-point">
                <strong>攻略を集約</strong>
                <span>記事、ビルド、マップ、素材情報をゲームごとに整理</span>
              </div>
              <div class="hero-point">
                <strong>更新を追いやすい</strong>
                <span>最近追加したページや更新履歴をトップから確認</span>
              </div>
              <div class="hero-point">
                <strong>自分用にも公開用にも</strong>
                <span>一般公開・限定公開の整理にもつなげやすい設計</span>
              </div>
            </div>
          </div>

          <div class="hero-visual">
            <div class="visual-card" role="img" aria-label="ファンタジーとSFが混ざるゲーム情報サイトのイメージ">
              <div class="visual-overlay">
                <div class="visual-label">Main Visual</div>
                <h2 class="visual-title">ロゴやキービジュアルを置く領域</h2>
                <p class="visual-text">
                  現在は仮のビジュアル領域です。後で SVG ロゴや各ゲームを象徴する画像へ差し替えやすい構成にしてあります。
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="games">
        <div class="container">
          <div class="section-header">
            <div>
              <h2 class="section-title">ゲーム一覧</h2>
              <p class="section-text">
                ゲームごとの入口を並べるメインエリアです。まずは主要タイトルをカード形式で見せると分かりやすくなります。
              </p>
            </div>
            <a class="section-link" href="#top">トップへ戻る</a>
          </div>

          <div class="game-grid">
            {games.map((game) => (
              <article class="card game-card">
                <div class={`game-thumb ${game.key}`}>
                  <span class="game-badge">{game.badge}</span>
                </div>
                <div class="game-body">
                  <h3 class="game-title">{game.title}</h3>
                  <p class="game-description">{game.description}</p>
                  <div class="tag-list">
                    {game.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                  <a class="card-link" href={game.href}>詳細を見る →</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section" id="updates">
        <div class="container">
          <div class="section-header">
            <div>
              <h2 class="section-title">最新記事 / 更新情報</h2>
              <p class="section-text">
                更新内容を数件だけ見せると、トップページが生きたサイトに見えやすくなります。
              </p>
            </div>
          </div>

          <div class="update-grid">
            {updates.map((item) => (
              <article class="card update-card">
                <div class="meta">{item.date}</div>
                <h3 class="update-title">{item.title}</h3>
                <p class="update-text">{item.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section" id="featured">
        <div class="container">
          <div class="section-header">
            <div>
              <h2 class="section-title">おすすめページ</h2>
              <p class="section-text">
                よく見てほしいページや、入口として便利なページを並べると回遊しやすくなります。
              </p>
            </div>
          </div>

          <div class="feature-grid">
            {featuredPages.map((page) => (
              <article class="card feature-card">
                <div class="meta">{page.label}</div>
                <h3 class="feature-title">{page.title}</h3>
                <p class="feature-text">{page.description}</p>
                <a class="card-link" href={page.href}>ページを見る →</a>
              </article>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <p class="brand-title">{site.name}</p>
          <p>
            遊んだゲームの攻略・データ・記録を整理するための個人用サイトです。公開ページと限定ページを将来的に分けやすい、素直なトップ構成にしてあります。
          </p>
        </div>

        <div class="footer-links">
          {navItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: #0f172a;
    --bg-soft: #111827;
    --panel: rgba(15, 23, 42, 0.72);
    --line: rgba(148, 163, 184, 0.18);
    --text: #e5eefb;
    --muted: #94a3b8;
    --accent: #7dd3fc;
    --accent-strong: #38bdf8;
    --shadow: 0 18px 50px rgba(0, 0, 0, 0.28);
    --max: 1180px;
    --radius-lg: 24px;
    --radius-md: 18px;
    --radius-sm: 14px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: "Segoe UI", "Hiragino Sans", "Noto Sans JP", sans-serif;
    color: var(--text);
    background:
      radial-gradient(circle at top left, rgba(56, 189, 248, 0.16), transparent 26%),
      radial-gradient(circle at top right, rgba(34, 197, 94, 0.14), transparent 22%),
      linear-gradient(180deg, #020617 0%, #0f172a 38%, #111827 100%);
    line-height: 1.7;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    width: min(calc(100% - 32px), var(--max));
    margin: 0 auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px);
    background: rgba(2, 6, 23, 0.7);
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    min-height: 76px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }

  .brand-mark {
    width: 48px;
    height: 48px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(125, 211, 252, 0.22), rgba(59, 130, 246, 0.18));
    border: 1px solid rgba(125, 211, 252, 0.28);
    display: grid;
    place-items: center;
    box-shadow: var(--shadow);
    flex-shrink: 0;
  }

  .brand-mark span {
    font-size: 1.35rem;
  }

  .brand-title {
    margin: 0;
    font-size: 1.02rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .brand-subtitle {
    margin: 2px 0 0;
    color: var(--muted);
    font-size: 0.82rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .header-nav a,
  .lang-switch a {
    padding: 10px 14px;
    border-radius: 999px;
    color: #dbe7f6;
    transition: 0.2s ease;
    font-size: 0.95rem;
  }

  .header-nav a:hover,
  .lang-switch a:hover {
    background: rgba(148, 163, 184, 0.12);
    color: #ffffff;
  }

  .lang-switch {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.58);
  }

  .lang-switch .is-active {
    background: linear-gradient(135deg, rgba(125, 211, 252, 0.22), rgba(56, 189, 248, 0.18));
    color: #ffffff;
    border: 1px solid rgba(125, 211, 252, 0.18);
  }

  .hero {
    padding: 72px 0 44px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 28px;
    align-items: stretch;
  }

  .hero-copy,
  .hero-visual {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }

  .hero-copy {
    padding: 40px;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(56, 189, 248, 0.12);
    border: 1px solid rgba(125, 211, 252, 0.2);
    color: #d9f5ff;
    font-size: 0.88rem;
    margin-bottom: 18px;
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(2.2rem, 4vw, 4.2rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .hero p {
    margin: 18px 0 0;
    color: #c8d7ea;
    font-size: 1.03rem;
    max-width: 60ch;
  }

  .hero-actions {
    margin-top: 28px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 600;
    transition: 0.2s ease;
  }

  .button-primary {
    background: linear-gradient(135deg, var(--accent), var(--accent-strong));
    color: #082032;
  }

  .button-primary:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }

  .button-secondary {
    border-color: rgba(148, 163, 184, 0.2);
    background: rgba(15, 23, 42, 0.5);
    color: #edf6ff;
  }

  .button-secondary:hover {
    background: rgba(30, 41, 59, 0.8);
  }

  .hero-points {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 26px;
  }

  .hero-point {
    padding: 14px 16px;
    border-radius: var(--radius-sm);
    background: rgba(2, 6, 23, 0.28);
    border: 1px solid rgba(148, 163, 184, 0.12);
  }

  .hero-point strong {
    display: block;
    font-size: 0.95rem;
    margin-bottom: 4px;
  }

  .hero-point span {
    font-size: 0.88rem;
    color: var(--muted);
  }

  .hero-visual {
    padding: 22px;
    display: flex;
    align-items: stretch;
  }

  .visual-card {
    width: 100%;
    min-height: 100%;
    border-radius: 20px;
    border: 1px solid rgba(125, 211, 252, 0.16);
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.1), rgba(2, 6, 23, 0.5)),
      radial-gradient(circle at 30% 20%, rgba(125, 211, 252, 0.16), transparent 28%),
      radial-gradient(circle at 80% 10%, rgba(74, 222, 128, 0.12), transparent 22%),
      linear-gradient(135deg, #0f172a, #111827);
    overflow: hidden;
    position: relative;
    display: grid;
    place-items: end start;
    padding: 26px;
  }

  .visual-overlay {
    max-width: 320px;
    background: rgba(2, 6, 23, 0.56);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 18px;
    padding: 18px;
  }

  .visual-label {
    color: #7dd3fc;
    font-size: 0.85rem;
    margin-bottom: 8px;
  }

  .visual-title {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.3;
  }

  .visual-text {
    margin: 10px 0 0;
    color: #c7d8eb;
    font-size: 0.94rem;
  }

  .section {
    padding: 24px 0;
  }

  .section-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }

  .section-title {
    margin: 0;
    font-size: clamp(1.5rem, 2vw, 2rem);
  }

  .section-text {
    margin: 8px 0 0;
    color: var(--muted);
    max-width: 60ch;
  }

  .section-link {
    color: #dff6ff;
    font-size: 0.95rem;
    white-space: nowrap;
  }

  .game-grid,
  .update-grid,
  .feature-grid {
    display: grid;
    gap: 18px;
  }

  .game-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .update-grid,
  .feature-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .game-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .game-thumb {
    aspect-ratio: 16 / 9;
    padding: 18px;
    display: flex;
    align-items: end;
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.18), rgba(15, 23, 42, 0.12));
    border-bottom: 1px solid rgba(148, 163, 184, 0.14);
  }

  .game-thumb.eso {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.2), rgba(30, 41, 59, 0.24));
  }

  .game-thumb.fo76 {
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.18), rgba(29, 78, 216, 0.22));
  }

  .game-thumb.ark {
    background: linear-gradient(135deg, rgba(74, 222, 128, 0.18), rgba(6, 78, 59, 0.24));
  }

  .game-thumb.future {
    background: linear-gradient(135deg, rgba(148, 163, 184, 0.14), rgba(51, 65, 85, 0.3));
  }

  .game-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 0.82rem;
    background: rgba(2, 6, 23, 0.44);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .game-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .game-title {
    margin: 0;
    font-size: 1.15rem;
  }

  .game-description,
  .update-text,
  .feature-text {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    display: inline-flex;
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 0.78rem;
    background: rgba(148, 163, 184, 0.1);
    color: #d5e3f4;
    border: 1px solid rgba(148, 163, 184, 0.12);
  }

  .card-link {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #c9f1ff;
    font-weight: 600;
    font-size: 0.92rem;
  }

  .update-card,
  .feature-card {
    padding: 22px;
  }

  .meta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    color: #cce6f6;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(56, 189, 248, 0.08);
    border: 1px solid rgba(125, 211, 252, 0.12);
    margin-bottom: 12px;
  }

  .update-title,
  .feature-title {
    margin: 0 0 10px;
    font-size: 1.05rem;
    line-height: 1.5;
  }

  .site-footer {
    margin-top: 46px;
    border-top: 1px solid rgba(148, 163, 184, 0.12);
    background: rgba(2, 6, 23, 0.48);
  }

  .footer-inner {
    padding: 26px 0 40px;
    display: flex;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .footer-brand {
    max-width: 520px;
  }

  .footer-brand p,
  .footer-links a {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  @media (max-width: 1080px) {
    .hero-grid,
    .game-grid,
    .update-grid,
    .feature-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-visual {
      min-height: 320px;
    }
  }

  @media (max-width: 820px) {
    .header-inner {
      flex-wrap: wrap;
      justify-content: center;
      padding: 12px 0;
    }

    .brand {
      width: 100%;
      justify-content: center;
    }

    .hero-copy {
      padding: 28px;
    }

    .hero-points {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .container {
      width: min(calc(100% - 24px), var(--max));
    }

    .hero {
      padding-top: 40px;
    }

    .hero-grid,
    .game-grid,
    .update-grid,
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .section-header,
    .footer-inner {
      display: block;
    }

    .section-link {
      display: inline-block;
      margin-top: 10px;
    }

